# ============================================================
# Staging — copie para .env.staging e preencha os valores reais.
# Em deploys (Vercel/Railway/etc.), prefira variáveis do painel
# do ambiente em vez de arquivos commitados.
# ============================================================

APP_ENV=staging
NEXT_PUBLIC_APP_ENV=staging
NODE_ENV=production
LOG_LEVEL=info

# Supabase (projeto de staging — separado do de prod)
NEXT_PUBLIC_SUPABASE_URL=https://STAGING_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Postgres (Supavisor pooled + direct para DDL)
DATABASE_URL=postgresql://postgres.STAGING_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
DATABASE_DIRECT_URL=postgresql://postgres.STAGING_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# Rate limit (recomendado em staging para refletir prod)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Sentry (error tracking)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# (Fase 4) R2 / Resend / PostHog — DSNs de staging
# CLOUDFLARE_R2_ACCESS_KEY_ID=
# RESEND_API_KEY=
# NEXT_PUBLIC_POSTHOG_KEY=
