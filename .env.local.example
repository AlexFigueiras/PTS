# ============================================================
# Ambiente da aplicação
# ============================================================
# local | staging | production. Independente de NODE_ENV.
APP_ENV=local
# Espelho público (NEXT_PUBLIC_*) é necessário para o browser (Sentry client etc.).
NEXT_PUBLIC_APP_ENV=local

# ============================================================
# Supabase
# ============================================================
# URL e chave anônima do projeto (Public — usadas no client + server)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Service role (server-only — NUNCA expor ao client). Usada para tarefas
# administrativas (jobs, migrations programáticas).
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ============================================================
# Postgres (via Supavisor)
# ============================================================
# Pooled (transaction mode) — usar no runtime da app. Porta 6543.
DATABASE_URL=postgresql://postgres.YOUR_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# Direta (porta 5432) — usar APENAS para drizzle-kit migrate/push/studio.
# Necessária porque DDL não é compatível com pooled transaction mode.
DATABASE_DIRECT_URL=postgresql://postgres.YOUR_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# ============================================================
# Rate Limiting (Upstash Redis) — opcional
# ============================================================
# Se ausentes, rate limit vira no-op (libera tudo). Recomendado em prod.
UPSTASH_REDIS_REST_URL=https://YOUR_DB.upstash.io
UPSTASH_REDIS_REST_TOKEN=

# ============================================================
# Observabilidade
# ============================================================
LOG_LEVEL=info

# ============================================================
# Cloudflare R2 (Storage/Uploads)
# ============================================================
# Endpoint S3-compatível do bucket R2. Formato:
#   https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# NUNCA expor ACCESS_KEY ou SECRET ao client (NEXT_PUBLIC_*).
CLOUDFLARE_R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
CLOUDFLARE_R2_ACCESS_KEY_ID=your_r2_access_key_id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
CLOUDFLARE_R2_BUCKET_NAME=caps-staging

# URL pública do bucket (exposta ao browser para montar URLs de acesso).
# Staging: URL pública direta do R2. Produção: custom domain ou Worker proxy.
# Presigned URLs NÃO usam esta variável — elas apontam direto ao endpoint S3/API.
NEXT_PUBLIC_R2_PUBLIC_URL=https://pub-YOUR_HASH.r2.dev

# ============================================================
# Resend (E-mail transacional)
# ============================================================
# API Key do Resend — server-only, NUNCA expor ao client (sem NEXT_PUBLIC_).
# Em local o provider vira noop (log no console). Obrigatório em staging/prod.
RESEND_API_KEY=re_YOUR_API_KEY

# Remetente padrão — opcional. Se ausente, usa 'BOSYN <suporte@mail.bosyn.com.br>'.
# Domínio deve estar verificado no painel Resend.
# NEXT_PUBLIC_ permite leitura no client (ex: exibir "e-mail enviado de...").
NEXT_PUBLIC_FROM_EMAIL=BOSYN <suporte@mail.bosyn.com.br>

# ============================================================
# Sentry (Error tracking)
# ============================================================
# DSN do projeto Sentry. Em local fica desligado por enabled=false (appEnv==='local'),
# mas pode preencher para testar manualmente quando quiser.
NEXT_PUBLIC_SENTRY_DSN=

# Build-only — para upload de source maps. Sem isso o build NÃO falha,
# só não sobe source maps (stack traces ficam ofuscadas em prod).
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
