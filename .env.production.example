# ============================================================
# Production — NUNCA commitar valores reais.
# Em deploys, configure via painel do ambiente (Vercel/etc.).
# Este arquivo serve apenas como referência das variáveis necessárias.
# ============================================================

APP_ENV=production
NEXT_PUBLIC_APP_ENV=production
NODE_ENV=production
LOG_LEVEL=info

# Supabase (projeto de PRODUÇÃO — separado de staging)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Postgres
DATABASE_URL=
DATABASE_DIRECT_URL=

# Rate limit (obrigatório em prod)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Sentry (error tracking)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# (Fase 4) R2 / Resend / PostHog
# CLOUDFLARE_R2_ACCESS_KEY_ID=
# RESEND_API_KEY=
# NEXT_PUBLIC_POSTHOG_KEY=
